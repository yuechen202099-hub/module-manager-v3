APP_NAME=module-manager-v2
APP_ENV=local
APP_SECRET=change-me
DEMO_AUTH_ENABLED=true

POSTGRES_DB=module_manager_v2
POSTGRES_USER=module_manager
POSTGRES_PASSWORD=module_manager_password
DATABASE_URL=postgresql+psycopg://module_manager:module_manager_password@postgres:5432/module_manager_v2
STATE_BACKEND=postgres

JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=720

STORAGE_BACKEND=local
OSS_ENDPOINT=
OSS_INTERNAL_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=
OSS_PREFIX=module-manager-v2
OSS_PUBLIC_BASE_URL=
OSS_SIGNED_URL_EXPIRE_SECONDS=3600
OSS_THUMBNAIL_PROCESS=image/resize,m_lfit,w_360,h_360/quality,q_75
OSS_PREVIEW_PROCESS=image/resize,m_lfit,w_1280,h_1280/quality,q_85

MAX_UPLOAD_MB=20
LOCAL_SIMULATION_STATE_PATH=
ADMIN_USERNAME=admin
ADMIN_TEAM_ID=default-team
ADMIN_PASSWORD=change-me
AUTH_USERS_PATH=
