page {
  min-height: 100vh;
  color: #101820;
  background: #eef2f5;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(16, 24, 32, 0.08), rgba(238, 242, 245, 0) 280rpx), #eef2f5;
}

.hero {
  padding: 28rpx 28rpx 22rpx;
  border-radius: 20rpx;
  color: #eff8fb;
  background: linear-gradient(135deg, #101820, #193040);
  box-shadow: 0 24rpx 58rpx rgba(16, 24, 32, 0.16);
}

.hero-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #9fb3c0;
  font-size: 24rpx;
  line-height: 1.5;
}

.panel {
  margin-top: 22rpx;
  border: 1rpx solid #d6e0e8;
  border-radius: 18rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 18rpx 46rpx rgba(16, 31, 45, 0.08);
}

.panel-head {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 18rpx 22rpx;
  border-bottom: 1rpx solid #dce4eb;
  background: linear-gradient(180deg, #fff, #f7f9fb);
}

.panel-title {
  font-size: 28rpx;
  font-weight: 900;
}

.muted {
  color: #637083;
  font-size: 23rpx;
  line-height: 1.5;
}

.panel-body {
  padding: 18rpx;
}

.field {
  display: grid;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.label {
  color: #566579;
  font-size: 24rpx;
  font-weight: 800;
}

.input {
  height: 78rpx;
  width: 100%;
  padding: 0 22rpx;
  border: 1rpx solid #d5e0e8;
  border-radius: 14rpx;
  color: #101820;
  background: #fff;
  font-size: 28rpx;
}

.button-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.btn {
  min-height: 76rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  padding: 0 26rpx;
  color: #07384a;
  background: #fff;
  border: 1rpx solid #cdd9e2;
  font-size: 27rpx;
  font-weight: 900;
}

.btn::after {
  border: 0;
}

.btn.primary {
  color: #fff;
  border-color: #0c6f88;
  background: #0c6f88;
}

.btn.ghost {
  color: #0c6f88;
  background: #eff8fb;
  border-color: #b9d9e2;
}

.btn.danger {
  color: #a32920;
  background: #fff6f4;
  border-color: #efc7c0;
}

.btn.full {
  width: 100%;
}

.badge {
  min-height: 40rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 10rpx;
  padding: 0 12rpx;
  color: #59687a;
  background: #eef2f5;
  font-size: 22rpx;
  font-weight: 900;
}

.badge.ok {
  color: #0b6c45;
  background: #e5f7ee;
}

.badge.warn {
  color: #8a5d0d;
  background: #fff4d8;
}

.card {
  display: grid;
  gap: 12rpx;
  padding: 20rpx;
  border: 1rpx solid #d8e2e9;
  border-radius: 16rpx;
  background: #fff;
}

.card + .card {
  margin-top: 14rpx;
}

.card.active {
  border-color: #0c6f88;
  box-shadow: inset 6rpx 0 0 #0c6f88;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  font-weight: 900;
}

.meta {
  color: #5d6d7f;
  font-size: 23rpx;
  line-height: 1.55;
}

.empty {
  min-height: 260rpx;
  display: grid;
  place-items: center;
  padding: 28rpx;
  color: #718093;
  text-align: center;
  border: 1rpx dashed #c5d1db;
  border-radius: 18rpx;
  background: #f8fbfc;
}

.safe-bottom {
  height: calc(28rpx + env(safe-area-inset-bottom));
}
