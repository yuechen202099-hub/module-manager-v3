<view class="page">
  <view class="hero">
    <view class="row">
      <view>
        <view class="hero-title">缓存中心</view>
        <view class="hero-subtitle">查看本机保存的施工资料组，联网后统一上传</view>
      </view>
      <view class="badge {{online ? 'ok' : 'warn'}}">{{online ? '在线' : '离线'}}</view>
    </view>
  </view>

  <view class="summary-grid">
    <view class="summary-card">
      <view class="muted">全部缓存</view>
      <view class="summary-number">{{summary.total}}</view>
    </view>
    <view class="summary-card ok">
      <view class="muted">可上传</view>
      <view class="summary-number">{{summary.ready}}</view>
    </view>
    <view class="summary-card warn">
      <view class="muted">需补齐</view>
      <view class="summary-number">{{summary.blocked}}</view>
    </view>
    <view class="summary-card">
      <view class="muted">历史缓存</view>
      <view class="summary-number">{{summary.stale}}</view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view>
        <view class="panel-title">缓存资料组</view>
        <view class="muted">{{uploadText}}</view>
      </view>
      <button class="btn ghost" bindtap="refresh">刷新</button>
    </view>
    <view class="panel-body">
      <view class="button-row cache-actions">
        <button class="btn" bindtap="backToTasks">返回任务</button>
        <button class="btn ghost" bindtap="clearHistory">清理历史</button>
        <button class="btn primary" bindtap="uploadAll" loading="{{uploading}}">统一上传完整缓存</button>
      </view>
      <view class="search-row">
        <input class="search-input" value="{{query}}" bindinput="onQueryInput" placeholder="搜索表号、地址、终端、采集器或模块号" />
        <button class="btn ghost clear-btn" bindtap="clearQuery">清空</button>
      </view>
      <block wx:if="{{items.length}}">
        <view wx:for="{{items}}" wx:key="client_batch_id" class="card {{item.stale ? 'stale' : item.ready ? 'ready' : 'blocked'}}" data-id="{{item.client_batch_id}}" bindtap="toggleDetail">
          <view class="row">
            <view class="name">{{item.meter_no || item.groupId || '资料组'}}</view>
            <view class="badge {{item.stale ? '' : item.ready ? 'ok' : 'warn'}}">{{item.statusLabel}}</view>
          </view>
          <view class="meta">终端 {{item.terminal || '-'}}</view>
          <view class="meta">{{item.address || '未填写地址'}}</view>
          <view class="meta">照片 {{item.photoCount}} 张 / {{item.kindLabel}}</view>
          <view class="meta" wx:if="{{item.staleText}}">原因：{{item.staleText}}</view>
          <view class="meta" wx:elif="{{item.missingText}}">缺少：{{item.missingText}}</view>
          <view wx:if="{{item.detailOpen}}" class="cache-detail" catchtap="stopEvent">
            <view class="edit-grid">
              <view class="edit-field">
                <text>终端</text>
                <input value="{{item.terminal}}" data-id="{{item.client_batch_id}}" data-field="terminal" bindinput="onEditInput" />
              </view>
              <view class="edit-field">
                <text>表号</text>
                <input value="{{item.meter_no}}" data-id="{{item.client_batch_id}}" data-field="meter_no" bindinput="onEditInput" />
              </view>
              <view class="edit-field full">
                <text>地址</text>
                <textarea value="{{item.address}}" data-id="{{item.client_batch_id}}" data-field="address" bindinput="onEditInput"></textarea>
              </view>
              <view class="edit-field">
                <text>采集器</text>
                <input value="{{item.collector}}" data-id="{{item.client_batch_id}}" data-field="collector" bindinput="onEditInput" />
              </view>
              <view class="edit-field">
                <text>模块号</text>
                <input value="{{item.module_asset_no}}" data-id="{{item.client_batch_id}}" data-field="module_asset_no" bindinput="onEditInput" />
              </view>
            </view>
            <view class="photo-list" wx:if="{{item.photos.length}}">
              <view wx:for="{{item.photos}}" wx:for-item="photo" wx:key="client_photo_id" class="photo-card" data-id="{{item.client_batch_id}}" data-src="{{photo.filePath}}" bindtap="previewPhoto">
                <image src="{{photo.filePath}}" mode="aspectFill"></image>
                <view>
                  <view class="photo-title">{{photo.label || photo.slot || '照片'}}</view>
                  <view class="meta">{{photo.filePath}}</view>
                </view>
              </view>
            </view>
            <view wx:else class="empty mini">暂无照片，回到施工采集页补齐必填照片</view>
            <view class="detail-row"><text>施工员</text><text>{{item.actor || '-'}}</text></view>
            <view class="detail-row"><text>团队</text><text>{{item.teamId || '-'}}</text></view>
            <view class="detail-row"><text>缓存编号</text><text>{{item.client_batch_id}}</text></view>
            <view class="button-row">
              <button class="btn primary" data-id="{{item.client_batch_id}}" catchtap="saveCacheEdit">保存修改</button>
              <button class="btn danger" data-id="{{item.client_batch_id}}" catchtap="removeCache">删除缓存</button>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty">暂无本机缓存</view>
    </view>
  </view>
  <view class="safe-bottom"></view>
</view>
