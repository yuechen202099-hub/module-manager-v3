.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.summary-card {
  min-height: 150rpx;
  padding: 22rpx;
  border: 1rpx solid #d6e0e8;
  border-radius: 18rpx;
  background: #fff;
  box-shadow: 0 18rpx 46rpx rgba(16, 31, 45, 0.08);
}

.summary-card.ok .summary-number {
  color: #0b6c45;
}

.summary-card.warn .summary-number {
  color: #8a5d0d;
}

.summary-number {
  margin-top: 14rpx;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 900;
}

.cache-actions {
  margin-bottom: 18rpx;
}

.cache-actions .btn {
  flex: 1;
}

.search-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 82rpx;
  border: 1rpx solid #cbd7e2;
  border-radius: 16rpx;
  padding: 0 22rpx;
  color: #111827;
  background: #fff;
  font-size: 28rpx;
}

.clear-btn {
  width: 128rpx;
}

.card.ready {
  border-color: #9bd3bf;
  background: #f7fffb;
}

.card.blocked {
  border-color: #efd28f;
  background: #fffaf0;
}

.card.stale {
  border-color: #c5ced8;
  background: #f6f8fa;
}

.cache-detail {
  margin-top: 18rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #dbe3ea;
}

.edit-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.edit-field {
  display: grid;
  gap: 8rpx;
  padding: 14rpx;
  border: 1rpx solid #d6e0e8;
  border-radius: 14rpx;
  background: #fff;
}

.edit-field.full {
  grid-column: 1 / -1;
}

.edit-field text {
  color: #667589;
  font-size: 23rpx;
  font-weight: 800;
}

.edit-field input,
.edit-field textarea {
  width: 100%;
  min-height: 58rpx;
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.45;
}

.edit-field textarea {
  min-height: 112rpx;
}

.photo-list {
  display: grid;
  gap: 12rpx;
  margin: 12rpx 0 16rpx;
}

.photo-card {
  display: grid;
  grid-template-columns: 150rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
  padding: 12rpx;
  border: 1rpx solid #d6e0e8;
  border-radius: 14rpx;
  background: #fff;
}

.photo-card image {
  width: 150rpx;
  height: 112rpx;
  border-radius: 12rpx;
  background: #e8eef3;
}

.photo-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.empty.mini {
  min-height: 110rpx;
  margin: 12rpx 0 16rpx;
  font-size: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0;
  color: #5f6f80;
  font-size: 24rpx;
}

.detail-row text:last-child {
  max-width: 430rpx;
  color: #111827;
  text-align: right;
  word-break: break-all;
}

.btn.danger {
  color: #fff;
  background: #a32920;
  border-color: #a32920;
}
