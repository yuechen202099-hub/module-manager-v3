.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 160rpx;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 18rpx;
}

.search {
  height: 88rpx;
  margin-bottom: 0;
  border-radius: 20rpx;
  font-size: 29rpx;
}

.meter-scan-btn {
  height: 88rpx;
  min-width: 0;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.filter-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.filter-btn {
  min-width: 0;
  height: 78rpx;
  border: 1rpx solid #d6e0e8;
  border-radius: 20rpx;
  color: #617083;
  background: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-btn.active {
  border-color: #0f6f8f;
  color: #06384a;
  background: #e4f2f6;
}

.logout-btn {
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

.cache-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin: 0 0 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(18, 102, 79, 0.24);
  border-radius: 22rpx;
  background: #f3fbf7;
}

.cache-action-text {
  min-width: 0;
  color: #12664f;
  font-size: 25rpx;
  font-weight: 800;
}

.cache-upload-btn {
  flex: 0 0 188rpx;
  height: 72rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.upload-hint {
  margin: -4rpx 0 16rpx;
  color: #617083;
  font-size: 24rpx;
  font-weight: 700;
}

.card.cached {
  border-color: #9bd3bf;
  background: #f7fffb;
}

.panel-body .card {
  gap: 14rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff, #f9fbfc);
  box-shadow: 0 12rpx 30rpx rgba(24, 39, 52, 0.07);
}

.panel-body .card + .card {
  margin-top: 16rpx;
}

.terminal-meta {
  display: none;
}

.address-line {
  display: -webkit-box;
  color: #334155;
  font-size: 27rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: normal;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.cache-line {
  color: #12664f;
  font-weight: 800;
}

.offline-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 24rpx;
  font-weight: 700;
}
