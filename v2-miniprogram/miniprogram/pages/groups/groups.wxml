<view class="page">
  <view class="hero">
    <view class="hero-title">未施工资料组</view>
    <view class="hero-subtitle">只显示当前终端下尚未上传施工照片的资料组</view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view>
        <view class="panel-title">资料组</view>
        <view class="muted">{{filteredGroups.length}} / {{groups.length}} 组 · {{snapshotText}}</view>
      </view>
      <view wx:if="{{offlineMode}}" class="offline-pill">离线包</view>
      <button class="btn ghost" bindtap="loadGroups" loading="{{loading}}">刷新</button>
      <button class="btn danger logout-btn" bindtap="logout">退出</button>
    </view>
    <view class="panel-body">
      <view class="search-row">
        <input class="input search" placeholder="搜表号、地址、弄号、车位号" value="{{query}}" bindinput="onQueryInput" />
        <button class="btn ghost meter-scan-btn" bindtap="scanMeter">扫表号</button>
      </view>
      <view class="filter-row">
        <button class="filter-btn {{statusFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="onStatusFilter">全部 {{filterCounts.all}}</button>
        <button class="filter-btn {{statusFilter === 'unconstructed' ? 'active' : ''}}" data-filter="unconstructed" bindtap="onStatusFilter">未施工 {{filterCounts.unconstructed}}</button>
        <button class="filter-btn {{statusFilter === 'cached' ? 'active' : ''}}" data-filter="cached" bindtap="onStatusFilter">已缓存 {{filterCounts.cached}}</button>
      </view>
      <view wx:if="{{statusFilter === 'cached'}}" class="cache-action-row">
        <view class="cache-action-text">{{filterCounts.cached ? '当前终端已缓存资料组可统一上传' : '当前筛选暂无缓存资料组'}}</view>
        <button class="btn primary cache-upload-btn" bindtap="uploadCached" loading="{{uploading}}" disabled="{{!filterCounts.cached}}">一键上传</button>
      </view>
      <view wx:if="{{uploadText}}" class="upload-hint">{{uploadText}}</view>
      <block wx:if="{{filteredGroups.length}}">
        <view wx:for="{{filteredGroups}}" wx:key="id" class="card {{item.isCached ? 'cached' : ''}}" data-id="{{item.id}}" bindtap="openCollect">
          <view class="row">
            <view class="name">{{item.meter_no || item.id}}</view>
            <view class="badge {{item.statusClass}}">{{item.statusText}}</view>
          </view>
          <view class="meta terminal-meta">终端 {{item.terminal || '-'}}</view>
          <view class="meta address-line">{{item.address || '未填写地址'}}</view>
          <view wx:if="{{item.isCached}}" class="meta cache-line">本机已缓存 {{item.cachePhotoCount}} 张{{item.cacheModule ? ' / 模块 ' + item.cacheModule : ''}}</view>
        </view>
      </block>
      <view wx:else class="empty">当前筛选下暂无资料组</view>
    </view>
  </view>
  <view class="safe-bottom"></view>
</view>
