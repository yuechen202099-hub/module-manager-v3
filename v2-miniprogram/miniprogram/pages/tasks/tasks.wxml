<view class="page">
  <view class="hero">
    <view class="row">
      <view>
        <view class="hero-title">施工任务</view>
        <view class="hero-subtitle">一个施工员最多同时处理 5 个终端任务</view>
      </view>
      <view class="badge {{online ? 'ok' : 'warn'}}">{{online ? '在线' : '离线'}}</view>
    </view>
    <view class="hero-actions">
      <button class="btn ghost" bindtap="openCache">缓存中心 {{queueCount}}</button>
    </view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view>
        <view class="panel-title">{{listTitle}}</view>
        <view class="muted">{{listHint}} / 可上传缓存 {{readyCacheCount}} 组</view>
      </view>
      <button class="btn ghost" bindtap="refresh" loading="{{loading}}">刷新</button>
    </view>
    <view class="panel-body">
      <block wx:if="{{tasks.length}}">
        <view wx:for="{{tasks}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="openTask">
          <view class="row">
            <view class="name">终端 {{item.terminal}}</view>
            <view class="badge {{item.statusClass}}">{{item.statusText}}</view>
          </view>
          <view class="meta">未施工 {{item.unconstructed_groups || 0}} 组 / 已上传 {{item.uploaded_groups || 0}} 组</view>
          <view class="meta">{{item.ownerText}}</view>
          <view class="button-row">
            <button class="btn primary" data-id="{{item.id}}" catchtap="claimTask">{{item.actionText}}</button>
            <button class="btn" data-id="{{item.id}}" catchtap="releaseTask" wx:if="{{item.construction_claimed_by === actor}}">释放</button>
          </view>
        </view>
      </block>
      <view wx:else class="empty">暂无可处理施工任务，请联系管理员指派终端</view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-body">
      <view class="button-row">
        <button class="btn ghost" bindtap="openCache">查看缓存并统一上传</button>
        <button class="btn danger" bindtap="logout">退出登录</button>
      </view>
    </view>
  </view>
  <view class="safe-bottom"></view>
</view>
