page {
  min-height: 100vh;
  background: #f6f9fc;
  color: #182230;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 10rpx;
  font-weight: 700;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
}

.muted {
  color: #667085;
}

.panel {
  border: 1rpx solid #d9e4ee;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, 0.06);
}

.status-tag {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border: 1rpx solid #c9d8e8;
  border-radius: 999rpx;
  background: #f2f7fc;
  color: #344054;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-button {
  background: #0a72d8;
  color: #fff;
}

.secondary-button {
  border: 1rpx solid #c9d8e8;
  background: #fff;
  color: #344054;
}
