.group-header,
.sheet-head,
.sheet-actions,
.draft-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.eyebrow {
  color: #0a72d8;
  font-size: 22rpx;
  font-weight: 800;
}

.heading {
  margin-top: 6rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
}

.scan-button,
.batch-button,
.close-button {
  min-width: 120rpx;
  min-height: 60rpx;
  font-size: 24rpx;
}

.search-row {
  margin-top: 20rpx;
}

.search-row input {
  height: 72rpx;
  padding: 0 20rpx;
  border: 1rpx solid #c9d8e8;
  border-radius: 12rpx;
  background: #fff;
}

.filter-tabs {
  margin-top: 18rpx;
  white-space: nowrap;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  height: 62rpx;
  margin-right: 12rpx;
  border: 1rpx solid #d9e4ee;
  border-radius: 999rpx;
  background: #fff;
  color: #526173;
  font-weight: 700;
}

.filter-tab.active {
  border-color: #0a72d8;
  background: #eaf4ff;
  color: #0a72d8;
}

.draft-toolbar {
  margin-top: 18rpx;
  padding: 18rpx;
}

.group-list {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.group-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx;
}

.group-main {
  flex: 1;
  min-width: 0;
}

.group-status {
  flex: 0 0 132rpx;
  width: 132rpx;
  height: 132rpx;
  align-self: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 1.2;
}

.meter {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.address {
  margin-top: 8rpx;
  color: #344054;
  line-height: 1.4;
}

.meta {
  display: grid;
  gap: 4rpx;
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
}

.exception-note,
.upload-error,
.error {
  margin-top: 12rpx;
  color: #b42318;
  font-size: 24rpx;
}

.empty {
  margin-top: 24rpx;
  padding: 28rpx;
  color: #667085;
  text-align: center;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(16, 24, 40, 0.36);
}

.collect-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  max-height: 90vh;
  padding: 18rpx 24rpx 28rpx;
  overflow-y: auto;
  border-radius: 28rpx 28rpx 0 0;
  background: #fff;
}

.sheet-handle {
  width: 84rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #d0d5dd;
}

.sheet-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.sheet-address {
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
}

.slot-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.photo-slot {
  min-height: 220rpx;
  overflow: hidden;
  border: 1rpx solid #d9e4ee;
  border-radius: 14rpx;
  background: #f8fbfd;
}

.photo-slot image,
.slot-empty {
  display: flex;
  width: 100%;
  height: 164rpx;
  align-items: center;
  justify-content: center;
  background: #eef4fa;
  color: #0a72d8;
  font-size: 56rpx;
  font-weight: 300;
}

.photo-slot text {
  display: block;
  padding: 12rpx;
  color: #344054;
  font-size: 23rpx;
  font-weight: 700;
}

.field-grid {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.field text {
  display: block;
  margin-bottom: 8rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 800;
}

.field-line {
  display: flex;
  gap: 10rpx;
}

.field input,
.field textarea {
  width: 100%;
  min-height: 72rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid #c9d8e8;
  border-radius: 12rpx;
  background: #fff;
}

.field textarea {
  height: 120rpx;
}

.mini-button {
  width: 86rpx;
  min-height: 72rpx;
  font-size: 24rpx;
}

.sheet-actions {
  position: sticky;
  bottom: 0;
  margin-top: 24rpx;
  padding-top: 18rpx;
  background: #fff;
}

.action-button {
  flex: 1;
  min-height: 78rpx;
}
